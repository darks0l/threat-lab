# Threat Lab — Environment Variables
# Copy this to .env.local and fill in the values

# ── Required for AI Analysis ──────────────────────────────────────────────────
# Bankr LLM gateway API key — enables multi-model AI threat analysis
# Get one at https://bankr.gg
BANKR_API_KEY=

# ── Optional: Live Threat Intel (Layer 2b) ───────────────────────────────────
# Brave Search API key — enables live threat intel from web + GitHub advisories
# Get one at https://brave.com/search/api
BRAVE_SEARCH_API_KEY=

# ── Optional: Malicious Package Detection ────────────────────────────────────
# Socket.dev API key — enables malicious package detection in dependency audits
# Get one at https://socket.dev
SOCKET_DEV_API_KEY=

# ── Optional: Higher Rate Limits ──────────────────────────────────────────────
# GitHub token — optional, improves GitHub Security Advisory rate limits
GITHUB_TOKEN=

# ── Deployment (Base Sepolia / Sepolia) ───────────────────────────────────────
# Private key for deployer wallet (NEVER commit this)
DEPLOYER_PRIVATE_KEY=

# ── RPC Endpoints ────────────────────────────────────────────────────────────
# Override default Anvil RPC URL
# ANVIL_RPC=http://127.0.0.1:8545

# Base Sepolia RPC (public default: https://sepolia.base.org)
# BASE_SEPOLIA_RPC=

# Mainnet RPC (for fork testing)
# MAINNET_RPC=

# Etherscan API key (for contract verification)
# BASESCAN_API_KEY=